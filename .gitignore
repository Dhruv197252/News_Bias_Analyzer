# Python bytecode & cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/

# Virtual environments (NEVER commit these)
venv/
env/
ENV/
bias_env/
.venv/

# Environment variables (contains secrets — NEVER commit)
.env
.env.local
.env.production
.env.staging

# ── ML Models (too large for git — use git-lfs or download script) ────────────
models/*.pkl
models/*.joblib
models/*.bin
models/*.h5
models/*.pt
models/*.onnx
!models/.gitkeep

# ── Large Datasets (download via data_pipeline.py or DVC) ────────────────────
data/raw/*.csv
data/raw/*.parquet
data/processed/*.csv
data/processed/*.pkl
!data/raw/.gitkeep
!data/processed/.gitkeep
# Keep external domain JSONs (small — OK to commit)
# data/external/*.json  ← intentionally NOT excluded

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
!logs/.gitkeep

# ── Frontend build artifacts ──────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── SQLite (dev DB — use PostgreSQL in production) ───────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
.cache/
